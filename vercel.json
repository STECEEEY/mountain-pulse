{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "git": {
    "deploymentEnabled": {
      "main": false,
      "master": false
    }
  },
  "rewrites": [
    {
      "source": "/api/deformation/(.*)",
      "destination": "http://47.102.147.118:8000/api/deformation/$1"
    },
    {
      "source": "/api/rainfall/(.*)",
      "destination": "http://47.102.147.118:5000/api/rainfall/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}