{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/api/timeseries",
      "destination": "http://47.102.147.118:8000/api/timeseries"
    },
    {
      "source": "/api/rainfall/(.*)",
      "destination": "http://47.102.147.118:5000/api/rainfall/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}